{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://effexorwinpe.local/contracts/diagnosis.schema.json",
  "title": "ANP Rescue diagnostic assessment",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_id", "generated_at", "mode", "summary", "findings", "questions", "next_steps", "limitations"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "report_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "mode": { "enum": ["offline_preflight", "online_agent"] },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "highest_severity", "finding_count"],
      "properties": {
        "headline": { "type": "string", "minLength": 1 },
        "highest_severity": { "$ref": "#/$defs/severity" },
        "finding_count": { "type": "integer", "minimum": 0 }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "severity", "confidence", "rationale", "evidence_refs"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "severity": { "$ref": "#/$defs/severity" },
          "confidence": { "enum": ["low", "medium", "high"] },
          "rationale": { "type": "string", "minLength": 1 },
          "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true }
        }
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "prompt", "reason", "answer_type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "prompt": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "answer_type": { "enum": ["yes_no", "free_text"] }
        }
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "operation", "risk", "requires_confirmation", "rationale"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "operation": {
            "enum": [
              "review_missing_sources",
              "identify_windows_installation",
              "select_windows_target",
              "inspect_bcd_entries",
              "inspect_storage_health",
              "review_bitlocker_access"
            ]
          },
          "risk": { "enum": ["read_only", "changes_system", "changes_boot", "changes_storage"] },
          "requires_confirmation": { "type": "boolean" },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
  },
  "$defs": {
    "severity": { "enum": ["info", "warning", "critical", "unknown"] }
  }
}
