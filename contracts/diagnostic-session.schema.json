{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://effexorwinpe.local/contracts/diagnostic-session.schema.json",
  "title": "EffexorWinPE diagnostic session",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "session_id", "report_id", "created_at", "updated_at", "symptoms", "answers", "events"],
  "properties": {
    "schema_version": { "const": "0.2.0" },
    "session_id": { "type": "string", "pattern": "^session-[a-f0-9]{24}$" },
    "report_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "symptoms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "recorded_at"],
        "properties": {
          "id": { "type": "string", "pattern": "^symptom-[a-f0-9]{24}$" },
          "text": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "recorded_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "answers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question_id", "value", "recorded_at"],
        "properties": {
          "question_id": { "type": "string", "minLength": 1 },
          "value": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "recorded_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["at", "kind"],
        "properties": {
          "at": { "type": "string", "format": "date-time" },
          "kind": {
            "enum": [
              "session_started",
              "symptom_recorded",
              "question_answered",
              "offline_assessment_created",
              "gateway_submitted",
              "online_assessment_received"
            ]
          },
          "reference": { "type": "string" }
        }
      }
    },
    "latest_assessment": { "$ref": "./diagnosis.schema.json" }
  }
}
