{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://effexorwinpe.local/contracts/diagnostic-report.schema.json",
  "title": "EffexorWinPE diagnostic report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "collected_at",
    "collector",
    "environment",
    "hardware",
    "storage",
    "boot",
    "windows_installations",
    "checks",
    "privacy"
  ],
  "properties": {
    "schema_version": { "const": "1.3.0" },
    "report_id": { "type": "string", "minLength": 16 },
    "collected_at": { "type": "string", "format": "date-time" },
    "collector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "effexorwinpe-collector" },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_os", "runtime_arch"],
      "properties": {
        "runtime_os": { "type": "string" },
        "runtime_arch": { "type": "string" },
        "hostname": {
          "type": "string",
          "description": "Potentially personal data; the UI must disclose it before upload."
        }
      }
    },
    "hardware": { "$ref": "#/$defs/hardware" },
    "storage": { "$ref": "#/$defs/storage" },
    "boot": { "$ref": "#/$defs/boot" },
    "windows_installations": {
      "type": "array",
      "items": { "$ref": "#/$defs/windowsInstallation" }
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contains_personal_data", "excluded_by_default"],
      "properties": {
        "contains_personal_data": { "type": "boolean" },
        "excluded_by_default": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    }
  },
  "$defs": {
    "nullableUInt": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "hardware": {
      "type": "object",
      "additionalProperties": false,
      "required": ["firmware_mode", "system", "processor", "memory", "network_adapters"],
      "properties": {
        "firmware_mode": { "enum": ["uefi", "bios", "unknown"] },
        "system": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "manufacturer": { "type": "string" },
            "model": { "type": "string" }
          }
        },
        "processor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cores", "logical_processors"],
          "properties": {
            "name": { "type": "string" },
            "cores": { "type": "integer", "minimum": 0 },
            "logical_processors": { "type": "integer", "minimum": 0 }
          }
        },
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total_physical_bytes"],
          "properties": {
            "total_physical_bytes": { "type": "integer", "minimum": 0 }
          }
        },
        "network_adapters": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "status": {
                "type": "string",
                "description": "Stable machine-readable NetConnectionStatus name such as media_disconnected, or unknown_<code> for unmapped values."
              },
              "status_code": {
                "type": ["integer", "null"],
                "description": "Raw Win32_NetworkAdapter.NetConnectionStatus value when available."
              }
            }
          }
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["disks", "drive_health", "partitions", "bitlocker_volumes", "bitlocker_inventory"],
      "properties": {
        "disks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["number", "size_bytes", "is_boot", "is_system"],
            "properties": {
              "number": { "type": "integer", "minimum": 0 },
              "friendly_name": { "type": "string" },
              "bus_type": { "type": "string" },
              "size_bytes": { "type": "integer", "minimum": 0 },
              "partition_style": { "type": "string" },
              "health_status": { "type": "string" },
              "operational_status": { "type": "string" },
              "is_boot": { "type": "boolean" },
              "is_system": { "type": "boolean" }
            }
          }
        },
        "drive_health": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["device_id", "temperature_celsius", "wear_percent", "power_on_hours", "read_errors_total", "write_errors_total"],
            "properties": {
              "device_id": { "type": "string" },
              "friendly_name": { "type": "string" },
              "media_type": { "type": "string" },
              "health_status": { "type": "string" },
              "temperature_celsius": { "$ref": "#/$defs/nullableUInt" },
              "wear_percent": { "$ref": "#/$defs/nullableUInt" },
              "power_on_hours": { "$ref": "#/$defs/nullableUInt" },
              "read_errors_total": { "$ref": "#/$defs/nullableUInt" },
              "write_errors_total": { "$ref": "#/$defs/nullableUInt" }
            }
          }
        },
        "partitions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["disk_number", "partition_number", "size_bytes", "is_active"],
            "properties": {
              "disk_number": { "type": "integer", "minimum": 0 },
              "partition_number": { "type": "integer", "minimum": 0 },
              "drive_letter": { "type": "string", "maxLength": 1 },
              "size_bytes": { "type": "integer", "minimum": 0 },
              "type": { "type": "string" },
              "gpt_type": { "type": "string" },
              "is_active": { "type": "boolean" }
            }
          }
        },
        "bitlocker_volumes": {
          "description": "BitLocker volumes when the provider was queried. Must be null when bitlocker_inventory.status is unavailable; an empty array means the provider succeeded and found no volumes.",
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/bitlockerVolume" }
        },
        "bitlocker_inventory": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": {
              "enum": ["ok", "unavailable", "partial"],
              "description": "ok = provider queried successfully; unavailable = provider/namespace failed; partial = some volume fields were incomplete."
            },
            "error": {
              "type": "string",
              "description": "Provider error details when status is unavailable or partial."
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "bitlocker_inventory": {
                "properties": { "status": { "const": "unavailable" } },
                "required": ["status"]
              }
            },
            "required": ["bitlocker_inventory"]
          },
          "then": {
            "properties": {
              "bitlocker_volumes": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "bitlocker_inventory": {
                "properties": { "status": { "enum": ["ok", "partial"] } },
                "required": ["status"]
              }
            },
            "required": ["bitlocker_inventory"]
          },
          "then": {
            "properties": {
              "bitlocker_volumes": {
                "type": "array",
                "items": { "$ref": "#/$defs/bitlockerVolume" }
              }
            }
          }
        }
      ]
    },
    "bitlockerVolume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mount_point"],
      "properties": {
        "mount_point": { "type": "string" },
        "volume_status": { "type": ["string", "null"] },
        "protection_status": { "type": ["string", "null"] },
        "lock_status": { "type": ["string", "null"] },
        "encryption_method": { "type": ["string", "null"] }
      }
    },
    "boot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["firmware_mode", "bcd_stores"],
      "properties": {
        "firmware_mode": { "enum": ["uefi", "bios", "unknown"] },
        "bcd_stores": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "kind"],
            "properties": {
              "path": { "type": "string" },
              "kind": { "enum": ["uefi", "bios"] }
            }
          }
        }
      }
    },
    "windowsInstallation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "system_hive", "software_hive"],
      "properties": {
        "root": { "type": "string" },
        "system_hive": { "type": "string" },
        "software_hive": { "type": "string" },
        "version": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "raw_product_name": {
              "type": "string",
              "description": "Unmodified ProductName from the offline SOFTWARE hive."
            },
            "product_name": {
              "type": "string",
              "description": "Normalized display name. Client builds >= 22000 rewrite legacy Windows 10 ProductName values to Windows 11; Server products are not rewritten."
            },
            "display_version": { "type": "string" },
            "edition_id": { "type": "string" },
            "installation_type": { "type": "string" },
            "build": { "type": "string" }
          }
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "summary"],
      "properties": {
        "id": { "type": "string" },
        "status": { "enum": ["ok", "warning", "error", "unknown"] },
        "summary": { "type": "string" }
      }
    }
  }
}
